# Monibase FX Trading App – environment variables
# Copy to .env and set values. Do not commit .env.

# App
NODE_ENV=development
PORT=3000

# PostgreSQL (TypeORM)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=monibase

# JWT
JWT_SECRET=your-secret-at-least-32-chars
JWT_EXPIRY=7d

# Mail (OTP, etc.) – e.g. Gmail SMTP or SendGrid
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com

# FX rates API (e.g. exchangerate-api.com)
FX_API_URL=https://v6.exchangerate-api.com/v6
FX_API_KEY=
FX_CACHE_TTL_SECONDS=300

# Redis (BullMQ for email queue; optional for FX cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional: app URL for links in emails
APP_URL=http://localhost:3000
